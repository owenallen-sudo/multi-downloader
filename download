mkdir -p "$HOME/.config/aria2dl"

# Logic for flag file
FLAGS_FILE="$HOME/.config/aria2dl/flags"
[[ ! -f "$FLAGS_FILE" ]] && touch "$FLAGS_FILE"

# Logic for addflag / removeflag
if [[ "$1" == "addflag" ]]; then
  SCRIPT_FLAG="$2"
  ARIA2C_FLAG="$4"  # $3 is "for"
  if [[ -z "$SCRIPT_FLAG" || -z "$ARIA2C_FLAG" ]]; then
    echo "Usage: aria2 addflag <scriptflag> for <aria2cflag>"
    exit 1
  fi
  grep -q "^$SCRIPT_FLAG:" "$FLAGS_FILE" && { echo "Flag exists, remove it first."; exit 1; }
  echo "$SCRIPT_FLAG:$ARIA2C_FLAG" >> "$FLAGS_FILE"
  echo "Added: $SCRIPT_FLAG -> $ARIA2C_FLAG"; exit 0
fi

if [[ "$1" == "removeflag" ]]; then
  SCRIPT_FLAG="$2"
  grep -v "^$SCRIPT_FLAG:" "$FLAGS_FILE" > "${FLAGS_FILE}.tmp" && mv "${FLAGS_FILE}.tmp" "$FLAGS_FILE"
  echo "Removed: $SCRIPT_FLAG"; exit 0
fi

# --- Defaults & Hardcoded Paths ---
# We check if they exist at the hardcoded path; if not, we use 'command -v' as a fallback.
CURL="/usr/bin/curl"
[[ ! -x "$CURL" ]] && CURL=$(command -v curl)

WGET="/usr/bin/wget" 
[[ ! -x "$WGET" ]] && WGET=$(command -v wget)

ARIA2C="/usr/bin/aria2c"
[[ ! -x "$ARIA2C" ]] && ARIA2C=$(command -v aria2c)

SURGE="/usr/bin/surge"
[[ ! -x "$SURGE" ]] && SURGE=$(command -v surge)

GIT="/usr/bin/git"
[[ ! -x "$GIT" ]] && GIT=$(command -v git)

TRICKLE="/usr/bin/trickle"
[[ ! -x "$TRICKLE" ]] && TRICKLE=$(command -v trickle)

FILEPATH="$HOME"
CHECK_CERT=true
DOWNLOAD_LIMIT="750K"
UPLOAD_LIMIT="1M"
STREAMS=12
MAX_SCRIPT_TRIES=3
CONTINUE=false
URI_SELECTOR=feedback
FILE_ALLOCATION=falloc
SAVING_INTERVAL=5
ALLOW_OVERWRITE=true
TIMEOUT=600
RETRY_WAIT=8
MAX_TRIES_INSIDE_ARIA2C=600
NTFY_TOPIC=download_on_pc
CONFIG_FILE="$HOME/.config/aria2dl/config"
NTFY_ENABLED=true
DOWNLOAD_ALL=false
COMPRESSION=true
USE_ARIA2=false
USE_CURL=false
USE_WGET=false
USE_GIT=false
USE_SURGE=false
ARIA2_SPEED_LIMITS=true
CURL_SPEED_LIMITS=true
WGET_SPEED_LIMITS=true
GIT_SPEED_LIMITS=true
GITHUB_TOKEN=""
GITHUB_BRANCH="main"
GITHUB_REPO=""
URL=""
EXTRA_ARGS=()

# Load config if exists (this allows overrides)
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# Parse flags
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --check-certificate=*) CHECK_CERT="${1#*=}" ;;
    --download-limit=*)    DOWNLOAD_LIMIT="${1#*=}" ;;
    --upload-limit=*)      UPLOAD_LIMIT="${1#*=}" ;;
    --streams=*)           STREAMS="${1#*=}" ;;
    --max-script-attempts=*) MAX_SCRIPT_TRIES="${1#*=}" ;;
    --filepath=*)          FILEPATH="${1#*=}" ;;
    --file-allocation=*)   FILE_ALLOCATION="${1#*=}" ;;
    --timeout=*)           TIMEOUT="${1#*=}" ;;
    --uri-selector=*)      URI_SELECTOR="${1#*=}" ;;
    --max-tries-inside-aria2=*) MAX_TRIES_INSIDE_ARIA2C="${1#*=}" ;;
    --retry-inside-aria2-wait=*) RETRY_WAIT="${1#*=}" ;;
    --saving-interval=*)   SAVING_INTERVAL="${1#*=}" ;;
    --allow-overwrite=*)   ALLOW_OVERWRITE="${1#*=}" ;;
    --ntfy-topic=*)        NTFY_TOPIC="${1#*=}" ;;
    --ntfy-enabled=*)      NTFY_ENABLED="${1#*=}" ;;
    --curl-path=*)         CURL="${1#*=}" ;;
    --wget-path=*)         WGET="${1#*=}" ;;
    --aria2-path=*)        ARIA2C="${1#*=}" ;; 
    --surge-path=*)         SURGE="${1#*=}" ;;
    --continue=*)          CONTINUE="${1#*=}" ;;
    --download-all-files=*) DOWNLOAD_ALL="${1#*=}" ;;
    --http-accept-gzip=*)  COMPRESSION="${1#*=}" ;;
    --use-aria2) USE_ARIA2=true ;;
    --use-surge) USE_SURGE=true ;;
    --use-curl) USE_CURL=true ;;
    --use-wget) USE_WGET=true ;;
    --use-git)             USE_GIT=true ;;
    --git-path=*)          GIT="${1#*=}" ;;
    --github-token=*)      GITHUB_TOKEN="${1#*=}" ;;
    --github-branch=*)            GITHUB_BRANCH="${1#*=}" ;;
    --aria2-speed-limits=*) ARIA2_SPEED_LIMITS="${1#*=}" ;;
    --curl-speed-limits=*)  CURL_SPEED_LIMITS="${1#*=}" ;;
    --wget-speed-limits=*)  WGET_SPEED_LIMITS="${1#*=}" ;;
    --git-speed-limits=*)   GIT_SPEED_LIMITS="${1#*=}" ;;
    -c)                    CONTINUE="true" ;;
    http*|ftp*|magnet*|sftp*|s3*|gs*|rsync*)
      if [[ "$1" == *"github.com"* ]] && [[ "$1" != *"/archive/"* ]]; then
        GITHUB_REPO=$(echo "$1" | grep -oP 'github\.com/\K[^/]+/[^/]+')
        URL="https://api.github.com/repos/$GITHUB_REPO/zipball/$GITHUB_BRANCH"
      else
        URL="$1"
      fi
      ;;
    *)
      if [[ "$1" == *"://"* ]]; then
        URL="$1"
        shift; continue
      fi
      MATCHED=false
      while IFS=: read -r SFLAG AFLAG; do
        if [[ "$1" == "$SFLAG" ]]; then
          EXTRA_ARGS+=("$AFLAG")
          MATCHED=true; break
        fi
      done < "$FLAGS_FILE"
      [[ "$MATCHED" == false ]] && echo "Unknown flag: $1"
      ;;
  esac
  shift
done

# Save back to config
cat > "$CONFIG_FILE" <<EOF
NTFY_TOPIC="$NTFY_TOPIC"
STREAMS="$STREAMS"
DOWNLOAD_LIMIT="$DOWNLOAD_LIMIT"
UPLOAD_LIMIT="$UPLOAD_LIMIT"
FILE_ALLOCATION="$FILE_ALLOCATION"
TIMEOUT="$TIMEOUT"
RETRY_WAIT="$RETRY_WAIT"
MAX_TRIES_INSIDE_ARIA2C="$MAX_TRIES_INSIDE_ARIA2C"
MAX_SCRIPT_TRIES="$MAX_SCRIPT_TRIES"
SAVING_INTERVAL="$SAVING_INTERVAL"
URI_SELECTOR="$URI_SELECTOR"
NTFY_ENABLED="$NTFY_ENABLED"
CURL="$CURL"
ARIA2C="$ARIA2C"
WGET="$WGET"
SURGE="$SURGE"
COMPRESSION="$COMPRESSION"
GIT="$GIT"
GITHUB_TOKEN="$GITHUB_TOKEN"
TRICKLE="$TRICKLE"
ARIA2_SPEED_LIMITS="$ARIA2_SPEED_LIMITS"
CURL_SPEED_LIMITS="$CURL_SPEED_LIMITS"
WGET_SPEED_LIMITS="$WGET_SPEED_LIMITS"
GIT_SPEED_LIMITS="$GIT_SPEED_LIMITS"
EOF

SURGE_CONFIG="$HOME/.config/surge/settings.json"
if [[ -f "$SURGE_CONFIG" ]] && command -v jq &>/dev/null; then
  tmp=$(mktemp)
  jq --argjson c "$STREAMS" '.network.max_connections_per_host = $c' "$SURGE_CONFIG" > "$tmp" && mv "$tmp" "$SURGE_CONFIG"
fi

# --- Helper Functions ---
to_kbps() {
  local val="${1^^}"
  if [[ "$val" == *K ]]; then echo "${val%K}"
  elif [[ "$val" == *M ]]; then echo $(( ${val%M} * 1024 ))
  elif [[ "$val" == *G ]]; then echo $(( ${val%G} * 1048576 ))
  else echo $(( $1 / 1024 ))
  fi
}

send_notification() {
  [[ "$NTFY_ENABLED" != "true" ]] && return
  "$CURL" -H "Title: $1" -H "Priority: default" -H "Tags: package,white_check_mark" -d "$2" "https://ntfy.sh/$NTFY_TOPIC"
}

crawl_urls() {
  "$WGET" --spider -r -nd -nv --no-parent "$1" 2>&1 | grep -oP 'https?://\S+' | grep -v '/$' | sort -u
}

build_aria2_input() {
  local base_url="${1%/}" dest_dir="$2" input_file="$3"
  > "$input_file"
  local count=0
  while IFS= read -r link; do
    local relative="${link#$base_url}"; relative="${relative#/}"
    local fdir=$(dirname "$relative"); local fname=$(basename "$relative")
    printf '%s\n  dir=%s/%s\n  out=%s\n\n' "$link" "$dest_dir" "$fdir" "$fname" >> "$input_file"
    ((count++))
  done < <(crawl_urls "$base_url")
  echo "Found $count files."
  [[ $count -gt 0 ]]
}

detect_folder_url() {
  [[ "$1" == */ ]] && echo "true" && return
  local effective
  effective=$("$CURL" -sI -L -o /dev/null -w '%{url_effective}' "$1")
  [[ "$effective" == */ ]] && echo "true" || echo "false"
}

# --- Execution ---
[[ -n "$GITHUB_REPO" ]] && URL="https://api.github.com/repos/$GITHUB_REPO/zipball/$GITHUB_BRANCH"
if [[ -z "$URL" ]]; then echo "Error: No URL."; exit 1; fi

# Path logic
if [[ "$FILEPATH" == */ ]] || [[ -d "$FILEPATH" ]]; then
  DIRPATH="${FILEPATH%/}"
  OUTFILE=$(basename "${URL%%\?*}")
else
  DIRPATH=$(dirname "$FILEPATH")
  OUTFILE=$(basename "$FILEPATH")
fi

mkdir -p "$DIRPATH"
SESSION_FILE="$DIRPATH/aria2.session"
LOGFILE="$DIRPATH/aria2.log"
[[ "$CONTINUE" != "true" ]] && > "$SESSION_FILE"

[[ "$DOWNLOAD_ALL" == "false" ]] && DOWNLOAD_ALL=$(detect_folder_url "$URL")

ATTEMPT=0
while [[ $ATTEMPT -lt $MAX_SCRIPT_TRIES ]]; do
  ((ATTEMPT++))

if [[ "$USE_GIT" == "true" ]] && [[ -n "$GITHUB_REPO" ]]; then
  echo "Attempt $ATTEMPT (git)..." | tee -a "$LOGFILE"
  CLONE_DIR="$DIRPATH/$(basename "$GITHUB_REPO")"
  GIT_CMD=("$GIT")
  if [[ "$GIT_SPEED_LIMITS" == "true" ]] && [[ -n "$TRICKLE" ]] && [[ -x "$TRICKLE" ]]; then
    GIT_CMD=("$TRICKLE" -d "$(to_kbps "$DOWNLOAD_LIMIT")" -u "$(to_kbps "$UPLOAD_LIMIT")" "$GIT")
  fi
  if [[ -n "$GITHUB_TOKEN" ]]; then
    AUTH_URL="https://$GITHUB_TOKEN@github.com/$GITHUB_REPO"
    if "${GIT_CMD[@]}" clone --branch "$GITHUB_BRANCH" "$AUTH_URL" "$CLONE_DIR"; then
      send_notification "Success" "Cloned $GITHUB_REPO"
      exit 0
    fi
  else
    if "${GIT_CMD[@]}" clone --branch "$GITHUB_BRANCH" "https://github.com/$GITHUB_REPO" "$CLONE_DIR"; then
      send_notification "Success" "Cloned $GITHUB_REPO"
      exit 0
    fi
  fi
  if [[ -n "$GITHUB_TOKEN" ]]; then
    AUTH_URL="https://$GITHUB_TOKEN@github.com/$GITHUB_REPO"
    if "$GIT" clone --branch "$GITHUB_BRANCH" "$AUTH_URL" "$CLONE_DIR"; then
      send_notification "Success" "Cloned $GITHUB_REPO"
      exit 0
    fi
  else
    if "$GIT" clone --branch "$GITHUB_BRANCH" "https://github.com/$GITHUB_REPO" "$CLONE_DIR"; then
      send_notification "Success" "Cloned $GITHUB_REPO"
      exit 0
    fi
  fi
elif [[ "$USE_CURL" == "true" ]]; then
  echo "Attempt $ATTEMPT (curl)..." | tee -a "$LOGFILE"
  CURL_LIMITS=()
  [[ "$CURL_SPEED_LIMITS" == "true" ]] && CURL_LIMITS+=(--limit-rate "$(to_kbps "$DOWNLOAD_LIMIT")K")
  if "$CURL" -L "${CURL_LIMITS[@]}" ${GITHUB_TOKEN:+-H "Authorization: token $GITHUB_TOKEN"} --output "$DIRPATH/$OUTFILE" "$URL"; then
    send_notification "Success" "Downloaded $URL"
    exit 0
  fi
elif [[ "$USE_WGET" == "true" ]]; then
  echo "Attempt $ATTEMPT (wget)..." | tee -a "$LOGFILE"
  WGET_LIMITS=()
  [[ "$WGET_SPEED_LIMITS" == "true" ]] && WGET_LIMITS+=(--limit-rate="$(to_kbps "$DOWNLOAD_LIMIT")K")
  if "$WGET" "${WGET_LIMITS[@]}" ${GITHUB_TOKEN:+--header="Authorization: token $GITHUB_TOKEN"} -O "$DIRPATH/$OUTFILE" "$URL"; then
    send_notification "Success" "Downloaded $URL"
    exit 0
  fi
elif [[ "$USE_SURGE" == "true" ]] || \
    ( [[ "$USE_ARIA2" != "true" ]] && [[ "$DOWNLOAD_ALL" != "true" ]] && \
    [[ "$URL" == http://* || "$URL" == https://* ]] && \
    [[ "$URL" != *"api.github.com"* ]] && \
    [[ -n "$SURGE" ]] && [[ -x "$SURGE" ]] ); then
  echo "Attempt $ATTEMPT (surge)..." | tee -a "$LOGFILE"
  if "$SURGE" "$URL" -o "$DIRPATH/$OUTFILE" --exit-when-done; then
    send_notification "Success" "Downloaded $URL"
    exit 0
  fi
else
  CMD=("$ARIA2C" -x "$STREAMS" -s "$STREAMS" --max-tries="$MAX_TRIES_INSIDE_ARIA2C" \
        --retry-wait="$RETRY_WAIT" --timeout="$TIMEOUT" --check-certificate="$CHECK_CERT" \
        --save-session="$SESSION_FILE" --save-session-interval="$SAVING_INTERVAL" \
        --allow-overwrite="$ALLOW_OVERWRITE" --file-allocation="$FILE_ALLOCATION")
  [[ "$ARIA2_SPEED_LIMITS" == "true" ]] && CMD+=(--max-overall-download-limit="$DOWNLOAD_LIMIT" --max-overall-upload-limit="$UPLOAD_LIMIT")

  if [[ "$DOWNLOAD_ALL" == "true" ]]; then
    INPUT_FILE="$DIRPATH/crawl.txt"
    build_aria2_input "$URL" "$DIRPATH" "$INPUT_FILE"
    CMD+=(--input-file="$INPUT_FILE")
  else
    CMD+=(--dir="$DIRPATH" -o "$OUTFILE" "$URL")
  fi

  [[ -n "$GITHUB_TOKEN" ]] && CMD+=(--header="Authorization: token $GITHUB_TOKEN")
  CMD+=("${EXTRA_ARGS[@]}")
  echo "Attempt $ATTEMPT (aria2c)..." | tee -a "$LOGFILE"
  if "${CMD[@]}"; then
    send_notification "Success" "Downloaded $URL"
    exit 0
  fi
fi
  sleep 2
done

send_notification "Failed" "Download failed after $MAX_SCRIPT_TRIES attempts"
exit 1
