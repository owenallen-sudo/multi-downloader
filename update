REPO="owenallen-sudo/download"
BRANCH=$(git -C "$(dirname "$0")" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CURL="/usr/bin/curl"
[[ ! -x "$CURL" ]] && CURL=$(command -v curl)

LOCAL_SHA=$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null)
REMOTE_SHA=$("$CURL" -sf "https://api.github.com/repos/$REPO/commits/$BRANCH" \
  | grep '"sha"' | head -1 | grep -oP '(?<=": ")[^"]+')

if [[ -z "$REMOTE_SHA" ]]; then
  echo "Error: could not fetch remote SHA."
  exit 1
fi

if [[ "$LOCAL_SHA" == "$REMOTE_SHA" ]]; then
  echo "Already up to date ($BRANCH @ ${LOCAL_SHA:0:7})."
  exit 0
fi

echo "Update available: ${LOCAL_SHA:0:7} -> ${REMOTE_SHA:0:7}"
echo "Updating $BRANCH branch..."
git -C "$SCRIPT_DIR" pull origin "$BRANCH"
echo "Updated successfully."
